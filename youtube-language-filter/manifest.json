{
  "manifest_version": 3,
  "name": "YouTube Language Filter",
  "version": "1.1.0",
  "description": "Filter YouTube search results to show only videos in your chosen language",
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.googleapis.com/",
    "https://translate.googleapis.com/"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "YouTube Language Filter — Settings"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
